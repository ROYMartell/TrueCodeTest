{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Yarp": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "truecode.users",
    "Audience": "truecode.clients",
    "SigningKey": "dev-signing-key-please-override-me-with-at-least-32-bytes",
    "AccessTtlMinutes": 15,
    "RefreshTtlDays": 7
  },
  "SwaggerSources": {
    "Users": "/api/users/swagger/v1/swagger.json",
    "Finance": "/api/finance/swagger/v1/swagger.json"
  },
  "ReverseProxy": {
    "Routes": {
      "users-swagger": {
        "Order": 0,
        "ClusterId": "users",
        "AuthorizationPolicy": "Anonymous",
        "Match": { "Path": "/api/users/swagger/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/api/users" }
        ]
      },
      "finance-swagger": {
        "Order": 0,
        "ClusterId": "finance",
        "AuthorizationPolicy": "Anonymous",
        "Match": { "Path": "/api/finance/swagger/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/api/finance" }
        ]
      },
      "users-public": {
        "Order": 1,
        "ClusterId": "users",
        "AuthorizationPolicy": "Anonymous",
        "Match": { "Path": "/api/users/register" }
      },
      "users-public-login": {
        "Order": 1,
        "ClusterId": "users",
        "AuthorizationPolicy": "Anonymous",
        "Match": { "Path": "/api/users/login" }
      },
      "users-public-refresh": {
        "Order": 1,
        "ClusterId": "users",
        "AuthorizationPolicy": "Anonymous",
        "Match": { "Path": "/api/users/refresh" }
      },
      "users-protected": {
        "Order": 100,
        "ClusterId": "users",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/api/users/{**catch-all}" }
      },
      "finance-protected": {
        "Order": 100,
        "ClusterId": "finance",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/api/finance/{**catch-all}" }
      }
    },
    "Clusters": {
      "users": {
        "Destinations": {
          "primary": { "Address": "http://localhost:5101/" }
        }
      },
      "finance": {
        "Destinations": {
          "primary": { "Address": "http://localhost:5102/" }
        }
      }
    }
  }
}
